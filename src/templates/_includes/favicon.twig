{#
	Favicon and web-app meta tags.

	siteName — used for the iOS web-app title
#}
{% set version = 1 %}

<link rel="icon" href="/favicon.ico?v={{ version }}" type="image/x-icon">
<link rel="icon" href="/favicon-16x16.png?v={{ version }}" sizes="16x16" type="image/png">
<link rel="icon" href="/favicon-32x32.png?v={{ version }}" sizes="32x32" type="image/png">
<link rel="icon" href="/android-chrome-192x192.png?v={{ version }}" sizes="192x192" type="image/png">
<link rel="icon" href="/android-chrome-512x512.png?v={{ version }}" sizes="512x512" type="image/png">
<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#ffffff">

{# Apple devices #}
<link rel="apple-touch-icon" href="/apple-touch-icon.png?v={{ version }}" sizes="180x180">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="{{ siteName }}">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
