# Do not export those files in the Composer archive (lighter dependency)
# The deploy workflows are deliberately NOT ignored — created projects ship with them
.gitattributes export-ignore
.github/icon.svg export-ignore
.github/workflows/release.yml export-ignore
CHANGELOG.md export-ignore
LICENSE.md export-ignore
README.md export-ignore

# Auto detect text files and perform LF normalization
* text=auto
