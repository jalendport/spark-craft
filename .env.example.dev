# Read about configuration, here:
# https://craftcms.com/docs/5.x/configure.html

# The application ID used to to uniquely store session and cache data, mutex locks, and more
CRAFT_APP_ID=

# The environment Craft is currently running in (dev, staging, production, etc.)
CRAFT_ENVIRONMENT=dev

# The secure key Craft will use for hashing and encrypting data
CRAFT_SECURITY_KEY=

# Database connection settings
CRAFT_DB_DRIVER=mysql
CRAFT_DB_SERVER=mysql
CRAFT_DB_PORT=3306
CRAFT_DB_DATABASE=app
CRAFT_DB_USER=root
CRAFT_DB_PASSWORD=root
CRAFT_DB_TABLE_PREFIX=

# Redis connection settings
REDIS_HOSTNAME=redis
REDIS_PORT=6379
REDIS_PASSWORD=root

# General settings (see config/general.php)
DEV_MODE=true
ALLOW_ADMIN_CHANGES=true
DISALLOW_ROBOTS=true

# App settings
APP_URL=http://localhost:8000

# Mailpit
MAILPIT_HOST=mailpit
MAILPIT_PORT=1025
# Web UI host port (change when another project already uses 8025)
#MAILPIT_UI_PORT=8025

# Vite
VITE_DEV_SERVER_PUBLIC=http://localhost:8080
